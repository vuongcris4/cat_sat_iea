+    def _prune_patterns_for_stage2(self, sols, top_k=800):
+        """Giảm số pattern đưa qua GĐ2: ưu tiên hao hụt thấp, bỏ gần-trùng theo (sum(x), round(loss))."""
+        sols = sorted(sols, key=lambda t: t[0], reverse=True)
+        kept, seen = [], set()
+        for obj, x in sols:
+            loss_mm = self.length - obj
+            sig = (sum(x), int(round(loss_mm)))
+            if sig in seen:
+                continue
+            seen.add(sig)
+            kept.append((obj, x))
+            if len(kept) >= top_k:
+                break
+        print(f"GĐ 1 -> GĐ 2: Cắt xuống còn {len(kept)} pattern.<br>")
+        return kept
