# Cat Sat IEA - Production Environment Variables
# Copy this file to .env and fill in the values

# Django
SECRET_KEY=change-me-to-a-random-50-char-string
DEBUG=False
ALLOWED_HOSTS=catsat.dongnama.app,localhost
CSRF_TRUSTED_ORIGINS=https://catsat.dongnama.app

# PostgreSQL
DB_NAME=catsat
DB_USER=catsat
DB_PASSWORD=change-me-strong-password
DB_HOST=postgres
DB_PORT=5432

# Redis
REDIS_HOST=redis
